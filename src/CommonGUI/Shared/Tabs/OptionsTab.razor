@using Blazored.Typeahead
@using BriefingRoom4DCS.GUI.Common.Shared.Sections
@using BriefingRoom4DCS.GUI.Utils
@using BriefingRoom4DCS.Template

@inject BriefingRoom4DCS.IBriefingRoom briefingRoom

<div id="options" class="generator-block">
    <h3>@briefingRoom.Translate("Options")</h3>
    <InputEnum Label="Fog of war" @bind-Value="Template.OptionsFogOfWar" EnumType="FogOfWar" />
    <div class="form-group flex-block">
        <label>@briefingRoom.Translate("RandomSeed") <span class="note">(@briefingRoom.Translate("RandomSeedNote"))</span></label>
        <input type="text" class="form-control" placeholder="e.g. 42"
               value="@(Template.RandomSeed.HasValue ? Template.RandomSeed.Value.ToString() : "")"
               @onchange="OnSeedChanged" />
    </div>
    <p class="custom-warning"><span class="oi oi-info"></span>&nbsp;@briefingRoom.Translate("RandomSeedHelp")</p>
    @if (Template.RandomSeed.HasValue)
    {
        <p class="custom-warning"><span class="oi oi-info"></span>&nbsp;@briefingRoom.Translate("RandomSeedActiveWarning")
        <a @onclick="() => Template.RandomSeed = null">@briefingRoom.Translate("ClearRandomSeed")</a></p>
    }
    <hr
    <input type="text" class="float-right" placeholder="Search" @bind="SearchTerm"  @bind:event="oninput" />
    <MissionFeatures Template="Template" SearchTerm="@SearchTerm" />
    <MissionOptions Template="Template" SearchTerm="@SearchTerm" />
</div>
@code {
    private string SearchTerm;
    [Parameter] public BuilderUtils builderUtils { get; set; }
    [Parameter] public MissionTemplate Template { get; set; }

    private void OnSeedChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString()?.Trim();
        if (string.IsNullOrEmpty(raw))
            Template.RandomSeed = null;
        else if (int.TryParse(raw, out int parsed))
            Template.RandomSeed = parsed;
    }
}